{
  "name": "trivia-dash",
  "version": "1.0.1",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "start:tunnel": "expo start --dev-client --tunnel",
    "start:go": "expo start --go",
    "start:web": "expo start --web",
    "android": "powershell -ExecutionPolicy Bypass -File ./scripts/run-android.ps1",
    "adb": "powershell -ExecutionPolicy Bypass -File ./scripts/adb.ps1",
    "android:raw": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "build:dev:android": "powershell -ExecutionPolicy Bypass -File ./scripts/eas-build.ps1 development android",
    "build:apk": "powershell -ExecutionPolicy Bypass -File ./scripts/eas-build.ps1 preview android",
    "build:play": "powershell -ExecutionPolicy Bypass -File ./scripts/eas-build.ps1 production android",
    "build:local:aab": "powershell -ExecutionPolicy Bypass -File ./scripts/local-release.ps1",
    "build:local:apk": "powershell -ExecutionPolicy Bypass -File ./scripts/local-apk.ps1",
    "build:dev:ios": "powershell -ExecutionPolicy Bypass -File ./scripts/eas-build.ps1 development ios",
    "smoke": "npx tsx scripts/smoke-test.ts",
    "smoke:bundle": "expo export --platform android --output-dir dist-smoke-test",
    "brand:export": "python scripts/export-brand-assets.py"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "@supabase/supabase-js": "^2.45.4",
    "babel-preset-expo": "~54.0.10",
    "expo": "^54.0.0",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-auth-session": "~7.0.11",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-sharing": "~14.0.8",
    "expo-speech": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-store-review": "~9.0.9",
    "expo-stores-games-services": "^0.1.13",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-google-mobile-ads": "^16.3.3",
    "react-native-purchases": "^10.2.2",
    "react-native-purchases-ui": "^10.2.2",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.1.10",
    "typescript": "^5.3.3"
  },
  "private": true
}
