{
  "expo": {
    "name": "Trivia Dash",
    "slug": "trivia-dash",
    "version": "1.0.2",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "triviadash",
    "icon": "./assets/icon.png",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0B16"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lizzi.triviadash"
    },
    "android": {
      "package": "com.lizzi.triviadash",
      "versionCode": 22,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B0B16"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "triviadash",
              "host": "auth",
              "pathPrefix": "/callback"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "permissions": [
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "revenueCatAndroidKey": "goog_rohSpQJUpYIIjVWBiWdgcbWceCJ",
      "eas": {
        "projectId": "620b1064-6081-4b91-95bc-dd4a3e0f2660"
      }
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24
          }
        }
      ],
      "./plugins/withRevenueCatAndroid",
      [
        "expo-audio",
        {
          "recordAudioAndroid": false,
          "microphonePermission": false
        }
      ],
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Trivia Dash to access your photos for profile and cover pictures.",
          "cameraPermission": "Allow Trivia Dash to take profile and cover photos."
        }
      ]
    ],
    "owner": "snookiebaby"
  }
}
