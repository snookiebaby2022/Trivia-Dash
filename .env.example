# Copy to .env and fill in from your Supabase project settings (Project Settings -> API).
# These are safe to expose in the client (anon key). The app falls back to a local
# mock leaderboard if these are left blank, so it still runs without a backend.
#
# After changing .env: stop Metro, run `npx expo start --dev-client -c`, and restart
# the dev build app on your device (force-close, then reopen). Expo Go / dev client
# only pick up EXPO_PUBLIC_* vars on a fresh bundle — reload alone is not enough.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Neural AI voices (OpenAI TTS via Supabase Edge Function — see supabase/functions/tts/)
# Requires: deploy tts function + supabase secrets set OPENAI_API_KEY=sk-...
EXPO_PUBLIC_AI_VOICE_ENABLED=true

# Google / Apple / Facebook Sign-In (configure in Supabase Dashboard):
# 1. Authentication -> Providers -> Enable Google, Apple, Facebook as needed
# 2. Add redirect URL: triviadash://auth/callback
# 3. Email sign-up works when Email provider is enabled (enabled by default)

# RevenueCat — see docs/REVENUECAT_PLAY_STORE.md
# Entitlement: pro · Play products: monthly, yearly · package: com.lizzi.triviadash
#
# Debug / Metro only (Test Store — do NOT use in release APKs):
# EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=test_xxxxxxxx
#
# Production (Google Play app in RevenueCat — required for live purchases):
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxxxxxx
EXPO_PUBLIC_REVENUECAT_IOS_KEY=

# Legal pages (host /legal/*.html on any HTTPS site, then paste URLs here + Play Console)
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://triviadashlegal.netlify.app/privacy-policy
EXPO_PUBLIC_TERMS_URL=https://triviadashlegal.netlify.app/terms
EXPO_PUBLIC_ACCOUNT_DELETION_URL=https://triviadashlegal.netlify.app/delete-account
EXPO_PUBLIC_SUPPORT_EMAIL=support@YOUR-DOMAIN

# AdMob — replace test IDs in src/lib/monetization.ts before store release
