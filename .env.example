# Copy to .env and fill in from your Supabase project settings (Project Settings -> API).
# These are safe to expose in the client (anon key). The app falls back to a local
# mock leaderboard if these are left blank, so it still runs without a backend.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# RevenueCat — https://www.revenuecat.com
# Entitlement identifier: pro (display name: Trivia Dash Pro)
# Google Play products: monthly, yearly
# Test Android key (also in app.json extra as fallback):
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=test_iAXldqIVnUOynJrZtrpubvDVoAx
EXPO_PUBLIC_REVENUECAT_IOS_KEY=

